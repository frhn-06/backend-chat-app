{
  "openapi": "3.0.0",
  "info": {
    "version": "v0.0.1",
    "title": "Dokumentasi API Chat App",
    "description": "ini adalah dokumenati rest API untuk backend dari aplikasi Chat App Realtime"
  },
  "servers": [
