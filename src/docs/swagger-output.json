  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer"
      }
    },
    "schemas": {
      "RegisterRequest": {
        "type": "object",
        "properties": {
          "fullName": {
            "type": "string",
            "example": "farhan"
          },
          "userName": {
            "type": "string",
            "example": "aan"
          },
          "email": {
            "type": "string",
            "example": "farhan@gmail.com"
          },
          "password": {
            "type": "string",
            "example": "psswrd"
          },
          "confirmPassword": {
            "type": "string",
            "example": "psswrd"
          }
        }
      },
      "Activation": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string",
            "example": "123"
          }
        }
      },
      "LoginRequest": {
        "type": "object",
        "properties": {
          "identifier": {
            "type": "string",
            "example": "email/username"
          },
          "password": {
            "type": "string",
            "example": "psswrd"
          }
        }
      },
      "MessageRequest": {
        "type": "object",
        "properties": {
          "targetId": {
            "type": "string",
            "example": ":id"
          },
          "text": {
            "type": "string",
            "example": ""
          }
        }
      }
    }
  }
}